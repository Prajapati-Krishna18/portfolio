{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/resume/(.*)",
      "destination": "/resume/$1"
    },
    {
      "source": "/certificates/(.*)",
      "destination": "/certificates/$1"
    },
    {
      "source": "/((?!api/|resume/|certificates/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
