# ===========================
# Server Configuration
# ===========================
PORT=5000
NODE_ENV=development

# ===========================
# MongoDB Atlas Connection
# ===========================
# Steps to get connection string:
# 1. Go to mongodb.com/atlas and create account
# 2. Create a FREE cluster (M0)
# 3. Database Access → Add database user
# 4. Network Access → Add IP: 0.0.0.0/0 (allows all)
# 5. Clusters → Connect → Drivers → Copy connection string
# Replace <password> with your database user password
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/portfolio_db?retryWrites=true&w=majority

# ===========================
# Email Configuration (Gmail)
# ===========================
# Steps to set up Gmail:
# 1. Enable 2FA at myaccount.google.com/security
# 2. Go to myaccount.google.com/apppasswords
# 3. Select "Mail" and "Other (Custom name)"
# 4. Copy the 16-character app password
EMAIL_SERVICE=gmail
EMAIL_USER=your.email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=Portfolio Contact <your.email@gmail.com>
EMAIL_TO=your.email@gmail.com

# ===========================
# CORS - Allowed Origins
# ===========================
# Comma-separated list of allowed frontend URLs
# Development: http://localhost:5173
# Production: https://your-portfolio.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
